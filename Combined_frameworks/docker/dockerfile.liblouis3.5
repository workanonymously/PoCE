# Dockerfile: Build Liblouis 3.5.0 with AddressSanitizer enabled
FROM ubuntu:18.04

ENV DEBIAN_FRONTEND=noninteractive
ENV LC_ALL=C.UTF-8
ENV LANG=C.UTF-8

ENV LIBLOUIS_VER=3.5.0
ENV PREFIX=/usr/local
ENV LIBLOUIS_URL=https://github.com/liblouis/liblouis/releases/download/v${LIBLOUIS_VER}/liblouis-${LIBLOUIS_VER}.tar.gz


RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    clang-10 \
    clang++-10 \
    libclang-dev \
    autoconf \
    automake \
    libtool \
    pkg-config \
    gettext \
    python3 \
    python3-distutils \
    git \
    ca-certificates \
    wget \
    && apt-get clean && rm -rf /var/lib/apt/lists/*


RUN update-alternatives --install /usr/bin/clang clang /usr/bin/clang-10 100 \
 && update-alternatives --install /usr/bin/clang++ clang++ /usr/bin/clang++-10 100


WORKDIR /usr/src
RUN wget -O liblouis-${LIBLOUIS_VER}.tar.gz ${LIBLOUIS_URL} && \
    tar xzf liblouis-${LIBLOUIS_VER}.tar.gz && \
    echo "Contents after extraction:" && \
    ls -la && \
    echo "Contents of liblouis directory:" && \
    ls -la liblouis-${LIBLOUIS_VER}/


ENV CFLAGS="-g -O1 -fsanitize=address -fno-omit-frame-pointer"
ENV CXXFLAGS="-g -O1 -fsanitize=address -fno-omit-frame-pointer"
ENV LDFLAGS="-fsanitize=address"
ENV CC=clang
ENV CXX=clang++


WORKDIR /usr/src/liblouis-${LIBLOUIS_VER}


RUN echo "Looking for build configuration files..." && \
    find . -name "configure" -o -name "autogen.sh" -o -name "configure.ac" -o -name "Makefile.am" | head -20


RUN set -e && \
    if [ -f "./autogen.sh" ]; then \
        echo "Building with autogen.sh" && \
        ./autogen.sh; \
    else \
        echo "No autogen.sh found, checking for configure script"; \
    fi && \
    if [ -f "./configure" ]; then \
        echo "Building with configure script" && \
        ./configure --prefix=${PREFIX}; \
    elif [ -f "./configure.ac" ]; then \
        echo "Found configure.ac, running autoconf" && \
        autoconf && \
        ./configure --prefix=${PREFIX}; \
    else \
        echo "ERROR: No configure script found!" && \
        echo "Available files:" && \
        ls -la && \
        exit 1; \
    fi

RUN make -j1 && make install


ENV ASAN_OPTIONS=verbosity=1:malloc_context_size=20
ENV LD_LIBRARY_PATH=${PREFIX}/lib:${LD_LIBRARY_PATH}

RUN ldconfig || true


WORKDIR /workspace


RUN apt-get update && apt-get install -y --no-install-recommends \
    file \
    && apt-get clean && rm -rf /var/lib/apt/lists/*


CMD ["/bin/bash"]
